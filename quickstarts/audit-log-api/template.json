{
  "id": "audit-log-api",
  "name": "Audit Log API",
  "version": "1.0.0",
  "description": "Append-only audit trail with intents, timeline projections, and named queries.",
  "category": "quickstarts",
  "difficulty": "beginner",
  "tags": [
    "quickstart",
    "audit",
    "timeline",
    "log",
    "beginner"
  ],
  "language": "causet",
  "runtime": "causet",
  "causetFiles": [
    "causet/app.causet",
    "causet/states/audit.state.causet",
    "causet/events/audit.events.causet",
    "causet/actions/audit.actions.causet",
    "causet/projections/audit.projections.causet",
    "causet/queries/audit.queries.causet"
  ],
  "requires": {
    "causetCli": ">=1.0.0",
    "causetCompiler": ">=1.0.0",
    "docker": false,
    "openaiKey": false
  },
  "secrets": [],
  "commands": {
    "compile": "causet build compile --runtime causet --out dist",
    "deploy": "causet deploy --fork {{causetFork}}"
  },
  "postCreateMessage": "Compile with `causet build compile --runtime causet --out dist`, deploy, then record actions and query the timeline with the CLI (see README.md)."
}
