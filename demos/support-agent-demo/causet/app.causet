# Support Agent — {{projectName}}
# Template: {{templateId}} · sourced from support-copilot
#
# Ticket submit → AI triage decision → projections → queries
#
#   causet build compile --runtime causet --out dist
#   open demo.html

dsl_version: 1
app: "{{packageName}}"

includes:
  states:
    - ./states/**/*.state.causet
  events:
    - ./events/**/*.events.causet
  actions:
    - ./actions/**/*.actions.causet
  providers:
    - ./providers/**/*.providers.causet
  prompts:
    - ./prompts/**/*.prompts.causet
  decisions:
    - ./decisions/**/*.decisions.causet
  memories:
    - ./memories/**/*.memories.causet
  listeners:
    - ./listeners/**/*.listeners.causet
  projections:
    - ./projections/**/*.projections.causet
  queries:
    - ./queries/**/*.queries.causet
